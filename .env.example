# ── Kompass configuration ─────────────────────────────────────────────
# Copy to `.env` and fill in. Only ANTHROPIC_API_KEY is required for the
# core demo; the rest have sane local defaults.

# ── Model provider (required) ─────────────────────────────────────────
OPENAI_API_KEY=sk-...

# Model routing (see kompass/models). "provider:model" strings resolved by
# langchain init_chat_model — swap provider by changing these lines only
# (e.g. anthropic:claude-sonnet-5 needs langchain-anthropic installed).
KOMPASS_MODEL_REASONING=openai:gpt-5.5
KOMPASS_MODEL_BALANCED=openai:gpt-5.4
KOMPASS_MODEL_FAST=openai:gpt-5.4-nano

# ── Retrieval ─────────────────────────────────────────────────────────
# Local Chroma path (no Docker needed). Switch to Qdrant via docker-compose.
KOMPASS_VECTOR_BACKEND=chroma          # chroma | qdrant
KOMPASS_CHROMA_PATH=.chroma
QDRANT_URL=http://localhost:6333
KOMPASS_ACME_DB=corpus/acme.db

# ── Persistence / durable HITL ────────────────────────────────────────
# sqlite = zero-setup local; postgres = durable/production (docker-compose).
KOMPASS_CHECKPOINTER=sqlite            # sqlite | postgres
KOMPASS_SQLITE_CHECKPOINT=kompass_checkpoints.db
POSTGRES_URL=postgresql://kompass:kompass@localhost:5432/kompass

# ── Observability (optional) ──────────────────────────────────────────
LANGFUSE_ENABLED=false
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ── Serving ───────────────────────────────────────────────────────────
KOMPASS_API_HOST=0.0.0.0
KOMPASS_API_PORT=8000
